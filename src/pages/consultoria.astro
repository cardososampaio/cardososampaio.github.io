---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { partnerships } from "../data/site";
---

<BaseLayout
  title="Consultoria"
  active="/consultoria/"
  description="Consultorias, parcerias e impacto público em democracia digital, IA, governança e comunicação política."
>
  <main>
    <PageHero
      eyebrow="Impacto e parcerias"
      title="Pesquisa aplicada para instituições que lidam com tecnologia e democracia."
      text="Rafael Sampaio atuou como consultor do Banco Mundial, Bertelsmann Foundation (Alemanha), Adam Smith International (Reino Unido), Organização de Estados Ibero-Americanos (OEI), Unesco, Ministério da Educação e já foi assessor de pesquisas do Comitê Gestor da Internet (CGI.br), Labhacker (Câmara dos Deputados), W3C Brasil e Centro de Estudos sobre Tecnologias Web, Instituto Democracia em Xeque e Transparência Internacional."
    />

    <section class="feature-grid">
      <article class="feature-card">
        <h2>Governança democrática</h2>
        <p>Rafael analisa políticas, plataformas, práticas institucionais e arranjos de participação, transparência e accountability.</p>
      </article>
      <article class="feature-card">
        <h2>IA e setor público</h2>
        <p>Seu trabalho examina usos, riscos, possibilidades e regulação de sistemas de inteligência artificial em ambientes públicos.</p>
      </article>
      <article class="feature-card">
        <h2>Comunicação política</h2>
        <p>Rafael desenvolve estudos sobre campanhas digitais, redes sociais, opinião pública, desinformação e circulação de argumentos.</p>
      </article>
      <article class="feature-card">
        <h2>Métodos e evidências</h2>
        <p>Ele contribui com desenho de pesquisa, análise de conteúdo, revisões, mapeamentos e sínteses para decisões orientadas por evidências.</p>
      </article>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Instituições e redes.</h2>
        <p>Rafael tem experiência em projetos e assessorias com organismos internacionais, instituições públicas, laboratórios e sociedade civil.</p>
      </div>
      <div class="tag-row">
        {partnerships.map((item) => <span>{item}</span>)}
      </div>
    </section>
  </main>
</BaseLayout>
