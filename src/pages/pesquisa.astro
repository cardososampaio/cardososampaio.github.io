---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { researchAreas, researchPrograms } from "../data/site";
---

<BaseLayout
  title="Pesquisa"
  active="/pesquisa/"
  description="Linhas de pesquisa de Rafael Cardoso Sampaio em democracia digital, comunicação política, IA e métodos."
>
  <main>
    <PageHero
      className="page-hero-wide"
      eyebrow="Agenda de pesquisa"
      title="Democracia, tecnologia e evidências."
      text="Rafael Sampaio desenvolve pesquisas em torno de diversos problemas públicos, como participação digital, deliberação online, campanhas, inteligência artificial, governo aberto e pesquisa qualitativa. Tem mais de 80 artigos publicados em periódicos Qualis, 14 livros entre coletâneas e autorais, quase 50 capítulos. Segundo o Google Scholar, ele tem índice H30 e mais de três mil citações, o que o coloca entre os 50 cientistas políticos mais citados do Brasil."
    />

    <section class="feature-grid">
      {researchPrograms.map((program) => (
        <article class="feature-card">
          <h2>{program.title}</h2>
          <p>{program.text}</p>
        </article>
      ))}
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Áreas de atuação.</h2>
        <p>Estes temas orientam projetos, orientações, publicações e parcerias acadêmicas de Rafael.</p>
      </div>
      <div class="tag-row">
        {researchAreas.map((area) => <span>{area}</span>)}
      </div>
    </section>
  </main>
</BaseLayout>
