---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { teachingThemes } from "../data/site";
---

<BaseLayout
  title="Ensino"
  active="/ensino/"
  description="Ensino, orientação e formação de pesquisadores em Ciência Política, comunicação política e métodos."
>
  <main>
    <PageHero
      eyebrow="Formação"
      title="Ensino para pesquisar problemas públicos com método."
      text="A página de ensino organiza áreas de docência, formação de pesquisadores e materiais que conectam métodos, política digital e escrita acadêmica responsável."
    />

    <section class="split-grid">
      <div>
        <h2>Temas de docência</h2>
        <p class="body-copy">Um repertório voltado a estudantes de graduação, pós-graduação e pesquisadores em formação.</p>
      </div>
      <ul class="list-clean">
        {teachingThemes.map((theme) => <li>{theme}</li>)}
      </ul>
    </section>

    <section class="section">
      <div class="feature-grid">
        <article class="feature-card">
          <h2>Orientação</h2>
          <p>Temas recorrentes incluem democracia digital, redes sociais, YouTube, desinformação, campanhas, consultas públicas, IA e participação política.</p>
        </article>
        <article class="feature-card">
          <h2>Materiais abertos</h2>
          <p>Livros e manuais funcionam como pontes entre pesquisa acadêmica, formação metodológica e uso responsável de tecnologias digitais.</p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
