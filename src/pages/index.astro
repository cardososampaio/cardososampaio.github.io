---
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationList from "../components/PublicationList.astro";
import { articles, profile, researchAreas, researchPrograms } from "../data/site";

const assetBase = import.meta.env.BASE_URL;
const scholarImage = `url("${assetBase}assets/google-scholar-impact.webp")`;
const withBase = (href: string) => href === "/" ? assetBase : `${assetBase}${href.replace(/^\//, "")}`;
---

<BaseLayout active="/">
  <main>
    <section class="hero home-hero">
      <div>
        <p class="eyebrow">{profile.shortRole}</p>
        <h1 class="sr-only">{profile.name}</h1>
        <p class="hero-copy lead-cv">
          Professor do Departamento de Ciência Política da Universidade Federal de Pernambuco.
          Rafael Sampaio é bolsista de produtividade do CNPq nível 1D, coordenador do
          Laboratório Interdisciplinar de Inteligência Artificial para Métodos, Democracia e
          Sociedade (<a class="text-link" href="https://labiialab.com.br/" target="_blank" rel="noreferrer">labiia_lab</a>)
          e pesquisador do <a class="text-link" href="https://inctparticipa.org/site/index.php/pt/" target="_blank" rel="noreferrer">INCT Participa</a>.
        </p>
        <p class="hero-copy lead-cv">
          Rafael Sampaio é doutor em Comunicação e Cultura Contemporâneas pela UFBA, com período
          sanduíche na University of Leeds, e realizou pós-doutorados na UFMG. Sua trajetória
          combina estudos sobre democracia digital, participação política online, deliberação,
          governo aberto, orçamentos participativos digitais, campanhas digitais, inteligência
          artificial e métodos de pesquisa.
        </p>
        <div class="cta-row">
          <a class="button primary" href={withBase("/publicacoes/")}>Publicações recentes</a>
          <a class="button" href={withBase("/consultoria/")}>Consultoria e impacto</a>
        </div>
        <div class="tag-row" aria-label="Áreas de pesquisa">
          {researchAreas.map((area) => <span>{area}</span>)}
        </div>
      </div>
      <aside class="profile-card">
        <img src={`${assetBase}assets/rafa-profile.webp`} alt="Retrato de Rafael Cardoso Sampaio" width="896" height="1152" />
        <div class="profile-meta">
          <div>
            <strong>COMPADD / INCT Participa</strong><br />
            <span>Pesquisa em política, tecnologia e democracia</span>
          </div>
          <div class="chip">UFPE</div>
        </div>
      </aside>
    </section>

    <section class="ribbon" aria-label="Destaques">
      <a class="ribbon-card" href={withBase("/pesquisa/")}>
        <h2>Pesquisa</h2>
        <p>Rafael pesquisa democracia digital, IA, participação, governo aberto, campanhas e campo científico.</p>
      </a>
      <a class="ribbon-card" href={withBase("/ensino/")}>
        <h2>Ensino</h2>
        <p>Rafael atua na formação de pesquisadores em métodos, política digital e escrita acadêmica.</p>
      </a>
      <a class="ribbon-card scholar-card" href={profile.scholarUrl} target="_blank" rel="noreferrer" style={`--scholar-image: ${scholarImage}`}>
        <h2>Scholar</h2>
        <p>A produção completa e os indicadores de circulação acadêmica estão no perfil público.</p>
      </a>
      <a class="ribbon-card" href={withBase("/consultoria/")}>
        <h2>Parcerias</h2>
        <p>Rafael colabora com instituições públicas, organizações internacionais e sociedade civil.</p>
      </a>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Pesquisa sobre problemas públicos.</h2>
        <p>
          A trajetória de Rafael cruza Ciência Política, Comunicação e tecnologias digitais,
          com atenção a evidências, métodos e consequências democráticas.
        </p>
      </div>
      <div class="feature-grid">
        {researchPrograms.map((program) => (
          <article class="feature-card">
            <h2>{program.title}</h2>
            <p>{program.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Publicações recentes.</h2>
        <p>
          A página de publicações reúne artigos de 2021 em diante, livros e capítulos em formato
          ABNT resumido, com links nos títulos.
        </p>
      </div>
      <PublicationList items={articles.slice(0, 6)} />
      <div class="cta-row">
        <a class="button primary" href={profile.scholarUrl}>Abrir Google Scholar</a>
        <a class="button" href={profile.lattesUrl}>Ver currículo Lattes</a>
      </div>
    </section>
  </main>
</BaseLayout>
