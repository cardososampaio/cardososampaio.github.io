---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import PublicationList from "../components/PublicationList.astro";
import { articles, books, chapters, profile } from "../data/site";
import { olderArticles } from "../data/olderArticles";

const totalArticles = articles.length + olderArticles.length;
---

<BaseLayout
  title="Publicações"
  active="/publicacoes/"
  description="Artigos recentes, livros e capítulos de Rafael Cardoso Sampaio."
>
  <main>
    <PageHero
      eyebrow="Produção acadêmica"
      title="Artigos, livros e capítulos."
      text="Esta página reúne os artigos de Rafael Sampaio, além de livros e capítulos registrados no currículo Lattes."
    />

    <section class="section publication-accordion" aria-label="Listas de publicações">
      <details class="accordion-panel" open>
        <summary>
          <span>Artigos</span>
          <small>{totalArticles} publicações</small>
        </summary>
        <div class="accordion-copy">
          <p>Referências em formato ABNT resumido. Os artigos desde 2021 aparecem primeiro; os anteriores ficam em uma seção recolhível.</p>
        </div>
        <div class="subsection-label">
          <h2>Desde 2021</h2>
          <span>{articles.length} publicações</span>
        </div>
        <PublicationList items={articles} />
        <details class="sub-accordion-panel">
          <summary>
            <span>Artigos anteriores a 2021</span>
            <small>{olderArticles.length} publicações</small>
          </summary>
          <PublicationList items={olderArticles} />
        </details>
      </details>

      <details class="accordion-panel">
        <summary>
          <span>Livros</span>
          <small>{books.length} publicações</small>
        </summary>
        <div class="accordion-copy">
          <p>Livros, manuais e e-books de pesquisa, formação metodológica e democracia digital.</p>
        </div>
        <PublicationList items={books} />
      </details>

      <details class="accordion-panel">
        <summary>
          <span>Capítulos</span>
          <small>{chapters.length} publicações</small>
        </summary>
        <div class="accordion-copy">
          <p>Capítulos de livros e verbetes acadêmicos organizados em ordem cronológica reversa.</p>
        </div>
        <PublicationList items={chapters} />
      </details>
    </section>

    <div class="cta-row">
      <a class="button primary" href={profile.scholarUrl}>Google Scholar</a>
      <a class="button" href={profile.lattesUrl}>Currículo Lattes</a>
      <a class="button" href={profile.orcidUrl}>ORCID</a>
    </div>
  </main>
</BaseLayout>
