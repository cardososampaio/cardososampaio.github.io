---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { profile } from "../data/site";

const assetBase = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contato"
  active="/contato/"
  description="Contato, redes acadêmicas e perfis públicos de Rafael Cardoso Sampaio."
>
  <main>
    <PageHero
      eyebrow="Contato"
      title="Canais para pesquisa, mídia e parcerias."
      text="Rafael Sampaio mantém perfis acadêmicos para consulta da produção completa e canais públicos para contato profissional."
    />

    <section class="contact-grid">
      <article class="contact-panel">
        <h2>Contato direto</h2>
        <p>Para convites, entrevistas, aulas, bancas, pesquisa aplicada e circulação pública do trabalho.</p>
        <dl class="contact-links">
          <div>
            <dt>E-mail</dt>
            <dd><a class="text-link" href={`mailto:${profile.email}`}>{profile.email}</a></dd>
          </div>
          <div>
            <dt>YouTube</dt>
            <dd><a class="text-link" href={profile.youtubeUrl}>@ProfessorRafaelSampaio</a></dd>
          </div>
          <div>
            <dt>Substack</dt>
            <dd><a class="text-link" href={profile.substackUrl}>substack.com/@cardososampaio</a></dd>
          </div>
        </dl>
      </article>
      <article class="contact-panel">
        <h2>Perfis</h2>
        <p>Produção acadêmica, identificadores e presença pública concentrados nos canais principais.</p>
        <dl class="contact-links contact-links-compact">
          <div>
            <dt>Google Scholar</dt>
            <dd><a class="text-link" href={profile.scholarUrl}>scholar.google.com.br</a></dd>
          </div>
          <div>
            <dt>Currículo Lattes</dt>
            <dd><a class="text-link" href={profile.lattesUrl}>lattes.cnpq.br</a></dd>
          </div>
          <div>
            <dt>ORCID</dt>
            <dd><a class="text-link" href={profile.orcidUrl}>orcid.org/0000-0001-5176-173X</a></dd>
          </div>
          <div>
            <dt>X / Twitter</dt>
            <dd><a class="text-link" href={profile.xUrl}>x.com/cardososampaio</a></dd>
          </div>
          <div>
            <dt>LinkedIn</dt>
            <dd><a class="text-link" href={profile.linkedinUrl}>linkedin.com/in/rafael-cardoso-sampaio-4a8b3822</a></dd>
          </div>
        </dl>
      </article>
      <article class="contact-panel image-panel">
        <img class="stranger-img" src={`${assetBase}assets/rafa-stranger-contact.webp`} alt="Ilustração em estilo retrofuturista de Rafael Cardoso Sampaio em ambiente de investigação" width="1061" height="1200" loading="lazy" />
      </article>
    </section>
  </main>
</BaseLayout>
