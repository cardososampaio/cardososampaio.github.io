---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { profile } from "../data/site";

const assetBase = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contato"
  active="/contato/"
  description="Contato, redes acadêmicas e perfis públicos de Rafael Cardoso Sampaio."
>
  <main>
    <PageHero
      eyebrow="Contato"
      title="Canais para pesquisa, mídia e parcerias."
      text="Use os perfis acadêmicos para produção completa e os canais públicos para contato profissional. O e-mail é revelado apenas por interação."
    />

    <section class="contact-grid">
      <article class="contact-panel">
        <h2>Mensagem direta</h2>
        <p>Para reduzir exposição automática, o e-mail não é escrito como texto puro no HTML inicial.</p>
        <button class="button primary email-button" type="button" data-email-trigger>Mostrar e-mail</button>
        <p class="email-output" data-email-output aria-live="polite"></p>
      </article>
      <article class="contact-panel">
        <h2>Perfis</h2>
        <ul class="list-clean">
          <li><a href={profile.scholarUrl}>Google Scholar</a></li>
          <li><a href={profile.lattesUrl}>Currículo Lattes</a></li>
          <li><a href={profile.orcidUrl}>ORCID</a></li>
          <li><a href={profile.xUrl}>X / Twitter</a></li>
          <li><a href={profile.linkedinUrl}>LinkedIn</a></li>
        </ul>
      </article>
      <article class="contact-panel">
        <h2>Fora do protocolo</h2>
        <p>Um detalhe menos rígido para a página de contato, sem contaminar a presença acadêmica do restante do site.</p>
        <img class="stranger-img" src={`${assetBase}assets/rafa-stranger-contact.webp`} alt="Ilustração em estilo retrofuturista de Rafael Cardoso Sampaio em ambiente de investigação" width="1061" height="1200" loading="lazy" />
      </article>
    </section>
  </main>
  <script>
    const trigger = document.querySelector("[data-email-trigger]");
    const output = document.querySelector("[data-email-output]");
    const codes = [99, 97, 114, 100, 111, 115, 111, 115, 97, 109, 112, 97, 105, 111, 64, 103, 109, 97, 105, 108, 46, 99, 111, 109];
    trigger?.addEventListener("click", () => {
      const address = String.fromCharCode(...codes);
      if (output) {
        output.innerHTML = `<a href="mailto:${address}">${address}</a>`;
      }
    });
  </script>
</BaseLayout>
