---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { profile } from "../data/site";

const assetBase = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contato"
  active="/contato/"
  description="Contato, redes acadêmicas e perfis públicos de Rafael Cardoso Sampaio."
>
  <main>
    <PageHero
      eyebrow="Contato"
      title="Canais para pesquisa, mídia e parcerias."
      text="Rafael Sampaio mantém perfis acadêmicos para consulta da produção completa e canais públicos para contato profissional."
    />

    <section class="contact-grid">
      <article class="contact-panel">
        <h2>Contato direto</h2>
        <p>Para convites, entrevistas, aulas, bancas, pesquisa aplicada e circulação pública do trabalho.</p>
        <ul class="contact-links">
          <li><a class="text-link" href={`mailto:${profile.email}`}>E-mail</a></li>
          <li><a class="text-link" href={profile.youtubeUrl} target="_blank" rel="noreferrer">YouTube</a></li>
          <li><a class="text-link" href={profile.substackUrl} target="_blank" rel="noreferrer">Substack</a></li>
        </ul>
      </article>
      <article class="contact-panel">
        <h2>Perfis</h2>
        <p>Produção acadêmica, identificadores e presença pública concentrados nos canais principais.</p>
        <ul class="contact-links contact-links-compact">
          <li><a class="text-link" href={profile.scholarUrl} target="_blank" rel="noreferrer">Google Scholar</a></li>
          <li><a class="text-link" href={profile.lattesUrl} target="_blank" rel="noreferrer">Currículo Lattes</a></li>
          <li><a class="text-link" href={profile.orcidUrl} target="_blank" rel="noreferrer">ORCID</a></li>
          <li><a class="text-link" href={profile.xUrl} target="_blank" rel="noreferrer">X</a></li>
          <li><a class="text-link" href={profile.linkedinUrl} target="_blank" rel="noreferrer">LinkedIn</a></li>
        </ul>
      </article>
      <article class="contact-panel image-panel">
        <img class="stranger-img" src={`${assetBase}assets/rafa-stranger-contact.webp`} alt="Ilustração em estilo retrofuturista de Rafael Cardoso Sampaio em ambiente de investigação" width="1061" height="1200" loading="lazy" />
      </article>
    </section>
  </main>
</BaseLayout>
